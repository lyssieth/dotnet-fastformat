root = true

[*]
indent_style = space
indent_size = 4
tab_width = 4
end_of_line = lf
insert_final_newline = true

[*.cs]
csharp_new_line_before_open_brace = all
csharp_indent_case_contents = true

# MA0004: This is a CLI/LSP process with no UI synchronization context; ConfigureAwait(false) adds noise without changing behavior here.
dotnet_diagnostic.MA0004.severity = none
# MA0048: Small internal DTO/helper types are intentionally grouped by feature to keep LSP/editorconfig plumbing readable.
dotnet_diagnostic.MA0048.severity = none
# MA0051: The remaining long methods are parser/protocol dispatch hotspots that are clearer kept linear than split mechanically.
dotnet_diagnostic.MA0051.severity = none
# MA0008: Internal LSP record structs are not used for interop or binary layout; StructLayout would be misleading.
dotnet_diagnostic.MA0008.severity = none
# MA0006: This codebase uses C# string operators for simple ordinal/null-safe equality; converting all sites would reduce readability.
dotnet_diagnostic.MA0006.severity = none
# MA0002: Existing collection defaults are intentional unless a specific lookup needs non-default path or string comparison semantics.
dotnet_diagnostic.MA0002.severity = none
# MA0158: Keep object locks until System.Threading.Lock is needed project-wide; current locks are private and low-contention.
dotnet_diagnostic.MA0158.severity = none